{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/diagnose.js": {
      "maxDuration": 60
    },
    "api/nearby.js": {
      "maxDuration": 25
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}